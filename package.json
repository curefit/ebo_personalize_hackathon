{
  "name": "ebo-smart-kiosk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "db:bootstrap": "bash scripts/node24.sh scripts/bootstrapCatalogDb.js",
    "db:import-nonmember-tags": "bash scripts/node24.sh scripts/importNonMemberTagFeed.js",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "bash scripts/node24.sh --env-file-if-exists=.env server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bash scripts/node24.sh --env-file-if-exists=.env server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.177.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "vite": "^8.0.8"
  }
}
